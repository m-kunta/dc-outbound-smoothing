# LevelSet Environment Configuration
# Copy this file to .env and fill in your values

# AI Provider (optional — only needed for planner insights feature)
# Options: Gemini, OpenAI, Anthropic, Groq, Ollama
LLM_PROVIDER=Gemini

# API Keys (only set the one you're using)
GEMINI_API_KEY=our_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Solver Parameters (optional — defaults shown)
LAMBDA=100      # OSA penalty weight (higher = protect service levels more)
GAMMA=1         # Early ship penalty weight (higher = pull forward less)
FROZEN_HOURS=48 # Hours ahead that are locked from rescheduling
HORIZON_DAYS=10 # Look-ahead window for trough search
